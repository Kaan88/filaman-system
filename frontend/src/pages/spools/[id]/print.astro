---
import Layout from '../../../layouts/Layout.astro'
import LabelDesignerEditor from '../../../components/LabelDesignerEditor.astro'
import SingleLabelPrintStyles from '../../../components/SingleLabelPrintStyles.astro'
import StandardLabelSettingsPanel from '../../../components/StandardLabelSettingsPanel.astro'

export function getStaticPaths() {
  return [
    {params: {id: 'detail'}},
  ];
}
---

<Layout title="FilaMan - Print Label">
  <SingleLabelPrintStyles />

  <div class="print-page">
    <aside class="print-sidebar">
      <div class="print-sidebar-scroll">
      <a id="btn-back" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="label-back">Zurück zur Spule</span>
      </a>

      <!-- Tab navigation -->
      <div class="tab-nav">
        <button class="tab-btn active" id="tab-btn-print" data-tab="print">Standard Label</button>
        <button class="tab-btn" id="tab-btn-designer" data-tab="designer">Label Designer</button>
      </div>

      <StandardLabelSettingsPanel idLabelI18n="spools.showSpoolId" idFallback="Spool ID" />

      <LabelDesignerEditor />

      </div><!-- /.print-sidebar-scroll -->

      <div class="action-buttons">
        <div class="export-buttons">
          <button id="btn-export-png" class="fm-btn fm-btn-outline" type="button">Export PNG</button>
          <button id="btn-export-pdf" class="fm-btn fm-btn-outline" type="button">Export PDF</button>
        </div>
        <button id="btn-print" class="fm-btn fm-btn-primary" onclick="filamanPrint()">Drucken</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline">Zurücksetzen</button>
      </div>
    </aside>

    <main class="preview-container">
      <div class="preview-zoom-bar">
        <button class="preview-zoom-btn" id="preview-zoom-out" title="Zoom out">−</button>
        <input type="range" id="preview-zoom-slider" min="50" max="300" step="5" value="100" class="preview-zoom-slider">
        <button class="preview-zoom-btn" id="preview-zoom-in" title="Zoom in">+</button>
        <span id="preview-zoom-label" class="preview-zoom-label">100%</span>
        <button class="preview-zoom-btn preview-zoom-reset" id="preview-zoom-reset" title="Reset zoom">⟳</button>
      </div>
      <div class="preview-scroll-area">
      <div id="label-preview" class="label-preview">
        <!-- Top: Logo area -->
        <div id="label-top" class="label-top">
          <img id="prev-logo" class="label-logo" alt="" />
          <div id="prev-mfr-text" class="label-mfr-text"></div>
        </div>
        <div id="label-top-divider" class="label-divider"></div>

        <!-- Middle: Designation + Color swatch -->
        <div id="label-middle" class="label-middle">
          <div class="label-middle-left">
            <div id="prev-filament" class="label-designation"></div>
            <div id="prev-color-row" class="label-color-row">
              <div id="prev-color-swatch" class="label-color-swatch"></div>
              <span id="prev-color-name" class="label-color-name"></span>
            </div>
          </div>
          <div id="prev-hex-code" class="label-hex-code"></div>
        </div>

        <!-- Bottom: ID + Extra fields left, QR right -->
        <div id="label-bottom" class="label-bottom">
          <div class="label-bottom-left">
            <div id="prev-id" class="label-spool-id"></div>
            <div id="prev-extra-fields" class="label-extra-fields"></div>
          </div>
          <div id="label-qr-container" class="label-qr"></div>
        </div>
      </div>
      </div>
    </main>
  </div>
</Layout>

<script>
  import { initLabelDesignerEditor } from '../../../lib/label-designer-editor'
  import {
    buildSpoolDataFromFlatLabel,
    getDesignerLabelDimensions,
    loadDesignerSettingsFromStorage,
    renderDesignerLabel,
  } from '../../../lib/label-designer'
  import {
    buildStandardLabelDataFromFlat,
    getStandardLabelDimensions,
    renderStandardLabel,
    type StandardExtraField,
    type StandardLabelSettings,
  } from '../../../lib/label-standard'
  import {
    LABEL_EXPORT_PIXEL_RATIO,
    bindPrintDesignerTabs,
    bindSingleLabelExport,
    buildLabelExportBaseName,
    clampInputValue,
    installPrintFunction,
    parseJsonOrNull,
    readPrintDesignerTab,
    readStorageValue,
    removeStorageValue,
    safeSetLocalStorage,
    type PrintDesignerTab,
    writeStorageValue,
  } from '../../../lib/label-print-page'

  // Auto-collapse nav sidebar on the print page when the viewport is narrow —
  // the print page needs maximum horizontal space and the overlay would cover the controls.
  function applyPrintSidebarCollapse() {
    const page = document.getElementById('fm-page')
    if (!page) return
    if (window.innerWidth < 1100) {
      document.documentElement.classList.add('sidebar-collapsed')
      page.classList.add('collapsed')
      if (window.innerWidth > 768) {
        writeStorageValue('sidebar-collapsed', 'true')
      }
    }
  }
  applyPrintSidebarCollapse()
  window.addEventListener('resize', applyPrintSidebarCollapse, { passive: true })

  installPrintFunction()

  type TranslationWindow = Window & { __t?: (key: string) => string }
  type SavedLabelSettings = {
    width?: unknown
    height?: unknown
    fontSize?: unknown
    qrSize?: unknown
    showLogo?: unknown
    showQR?: unknown
    showID?: unknown
    showMfr?: unknown
    showMat?: unknown
    showColor?: unknown
    showColorSwatch?: unknown
    showColorHex?: unknown
    extraFields?: unknown
  }

  const translate = (key: string, fallback = '') => (window as TranslationWindow).__t?.(key) || fallback

  const id = window.location.pathname.split('/').filter(Boolean).slice(-2, -1)[0]

  const params = new URLSearchParams(window.location.search)
  const labelData = {
    id: id,
    filament_id: params.get('filament_id') || '',
    designation: params.get('designation') || '',
    manufacturer: params.get('mfr') || '',
    manufacturer_id: params.get('manufacturer_id') || params.get('mfr_id') || '',
    type: params.get('type') || '',
    color: params.get('color') || '',
    colors: params.get('colors') || '',
    subtype: params.get('subtype') || '',
    mfr_id: params.get('mfr_id') || '',
    hex_code: params.get('hex_code') || '',
    color_hexes: params.get('color_hexes') || '',
    color_mode: params.get('color_mode') || '',
    multi_color_style: params.get('multi_color_style') || '',
    extruder_temp: params.get('extruder_temp') || '',
    bed_temp: params.get('bed_temp') || '',
    raw_material_weight_g: params.get('raw_material_weight_g') || params.get('weight') || '',
    weight: params.get('weight') || '',
    diameter: params.get('diameter') || '',
    finish: params.get('finish') || '',
    density: params.get('density') || '',
    price: params.get('price') || '',
    manufacturer_color_name: params.get('color_name') || '',
    default_spool_weight_g: params.get('default_spool_wt') || '',
    spool_outer_diameter_mm: params.get('spool_outer_dia') || '',
    spool_width_mm: params.get('spool_width') || '',
    spool_material: params.get('spool_material') || '',
    shop_url: params.get('shop_url') || '',
    lot_number: params.get('lot') || '',
    external_id: params.get('ext_id') || '',
    rfid_uid: params.get('rfid') || '',
    location: params.get('location') || '',
    status: params.get('status') || '',
    purchase_date: params.get('purchase_date') || '',
    purchase_price: params.get('purchase_price') || '',
    remaining_weight_g: params.get('remaining_wt') || '',
    initial_total_weight_g: params.get('initial_wt') || '',
    empty_spool_weight_g: params.get('empty_spool_wt') || '',
    low_weight_threshold_g: params.get('low_wt') || '',
    stocked_in_at: params.get('stocked_in') || '',
    last_used_at: params.get('last_used') || '',
  }

  function toLabelString(value: unknown): string {
    return value === undefined || value === null ? '' : String(value)
  }

  function firstValue(...values: unknown[]): string {
    for (const value of values) {
      const text = toLabelString(value)
      if (text) return text
    }
    return ''
  }

  type ApiColorEntry = {
    display_name_override?: unknown
    color?: { name?: unknown; hex_code?: unknown }
  }
  type ApiFilamentForPrint = {
    id?: unknown
    manufacturer_id?: unknown
    designation?: unknown
    material_type?: unknown
    type?: unknown
    material_subgroup?: unknown
    manufacturer_color_name?: unknown
    finish_type?: unknown
    raw_material_weight_g?: unknown
    default_spool_weight_g?: unknown
    spool_outer_diameter_mm?: unknown
    spool_width_mm?: unknown
    spool_material?: unknown
    price?: unknown
    shop_url?: unknown
    density_g_cm3?: unknown
    diameter_mm?: unknown
    color_mode?: unknown
    multi_color_style?: unknown
    custom_fields?: Record<string, unknown>
    colors?: ApiColorEntry[]
    filament_colors?: ApiColorEntry[]
    manufacturer?: {
      id?: unknown
      name?: unknown
      spool_outer_diameter_mm?: unknown
      spool_width_mm?: unknown
      spool_material?: unknown
    }
  }
  type ApiSpoolForPrint = {
    filament_id?: unknown
    lot_number?: unknown
    rfid_uid?: unknown
    external_id?: unknown
    purchase_date?: unknown
    purchase_price?: unknown
    stocked_in_at?: unknown
    last_used_at?: unknown
    initial_total_weight_g?: unknown
    empty_spool_weight_g?: unknown
    remaining_weight_g?: unknown
    spool_outer_diameter_mm?: unknown
    spool_width_mm?: unknown
    spool_material?: unknown
    low_weight_threshold_g?: unknown
    custom_fields?: Record<string, unknown>
    filament?: ApiFilamentForPrint
    status?: { label?: unknown }
    location?: { label?: unknown; name?: unknown }
  }

  function getApiFilamentColors(filament: ApiFilamentForPrint): ApiColorEntry[] {
    const list = Array.isArray(filament?.filament_colors)
      ? filament.filament_colors
      : filament?.colors
    return Array.isArray(list) ? list : []
  }

  function applySpoolApiData(spool: ApiSpoolForPrint) {
    const filament = spool?.filament ?? {}
    const manufacturer = filament?.manufacturer ?? {}
    const colors = getApiFilamentColors(filament)
    const firstColor = colors[0] ?? {}
    const colorNames = colors
      .map(color => color?.display_name_override || color?.color?.name)
      .filter(Boolean)
      .join(', ')
    const colorHexes = colors
      .map(color => color?.color?.hex_code)
      .filter(Boolean)
      .join(', ')

    Object.assign(labelData, {
      filament_id: firstValue(spool?.filament_id, labelData.filament_id),
      designation: firstValue(filament?.designation, labelData.designation),
      manufacturer: firstValue(manufacturer?.name, labelData.manufacturer),
      manufacturer_id: firstValue(filament?.manufacturer_id, manufacturer?.id, labelData.manufacturer_id),
      type: firstValue(filament?.material_type, filament?.type, labelData.type),
      subtype: firstValue(filament?.material_subgroup, labelData.subtype),
      color: firstValue(firstColor?.display_name_override, filament?.manufacturer_color_name, firstColor?.color?.name, labelData.color),
      colors: firstValue(colorNames, labelData.colors),
      hex_code: firstValue(firstColor?.color?.hex_code, labelData.hex_code),
      color_hexes: firstValue(colorHexes, labelData.color_hexes),
      color_mode: firstValue(filament?.color_mode, labelData.color_mode),
      multi_color_style: firstValue(filament?.multi_color_style, labelData.multi_color_style),
      extruder_temp: firstValue(filament?.custom_fields?.extruder_temp, labelData.extruder_temp),
      bed_temp: firstValue(filament?.custom_fields?.bed_temp, labelData.bed_temp),
      raw_material_weight_g: firstValue(filament?.raw_material_weight_g, labelData.raw_material_weight_g),
      weight: firstValue(filament?.raw_material_weight_g, labelData.weight),
      diameter: firstValue(filament?.diameter_mm, labelData.diameter),
      finish: firstValue(filament?.finish_type, labelData.finish),
      density: firstValue(filament?.density_g_cm3, labelData.density),
      price: firstValue(filament?.price, labelData.price),
      manufacturer_color_name: firstValue(filament?.manufacturer_color_name, labelData.manufacturer_color_name),
      default_spool_weight_g: firstValue(filament?.default_spool_weight_g, labelData.default_spool_weight_g),
      spool_outer_diameter_mm: firstValue(spool?.spool_outer_diameter_mm, filament?.spool_outer_diameter_mm, manufacturer?.spool_outer_diameter_mm, labelData.spool_outer_diameter_mm),
      spool_width_mm: firstValue(spool?.spool_width_mm, filament?.spool_width_mm, manufacturer?.spool_width_mm, labelData.spool_width_mm),
      spool_material: firstValue(spool?.spool_material, filament?.spool_material, manufacturer?.spool_material, labelData.spool_material),
      shop_url: firstValue(filament?.shop_url, labelData.shop_url),
      mfr_id: firstValue(manufacturer?.id, filament?.manufacturer_id, labelData.mfr_id),
      lot_number: firstValue(spool?.lot_number, labelData.lot_number),
      external_id: firstValue(spool?.external_id, labelData.external_id),
      rfid_uid: firstValue(spool?.rfid_uid, labelData.rfid_uid),
      location: firstValue(spool?.location?.label, spool?.location?.name, labelData.location),
      status: firstValue(spool?.status?.label, labelData.status),
      purchase_date: firstValue(spool?.purchase_date, labelData.purchase_date),
      purchase_price: firstValue(spool?.purchase_price, labelData.purchase_price),
      remaining_weight_g: firstValue(spool?.remaining_weight_g, labelData.remaining_weight_g),
      initial_total_weight_g: firstValue(spool?.initial_total_weight_g, labelData.initial_total_weight_g),
      empty_spool_weight_g: firstValue(spool?.empty_spool_weight_g, labelData.empty_spool_weight_g),
      low_weight_threshold_g: firstValue(spool?.low_weight_threshold_g, labelData.low_weight_threshold_g),
      stocked_in_at: firstValue(spool?.stocked_in_at, labelData.stocked_in_at),
      last_used_at: firstValue(spool?.last_used_at, labelData.last_used_at),
    })
  }

  async function fetchSpoolApiData() {
    try {
      const response = await fetch(`/api/v1/spools/${id}`, { credentials: 'include' })
      if (!response.ok) return null
      const spool = await response.json()
      applySpoolApiData(spool)
      return spool
    } catch {
      return null
    }
  }


  let extraFields: {key: string, label: string, value: string, source?: string}[] = []
  try {
    const stored = sessionStorage.getItem('filaman-label-extra-fields')
    if (stored) {
      const parsed = JSON.parse(stored)
      if (Array.isArray(parsed)) {
        extraFields = parsed.filter((item) => (
          item &&
          typeof item.key === 'string' &&
          typeof item.label === 'string' &&
          typeof item.value === 'string'
        ))
      }
    }
  } catch { /* ignore */ }

  // Flat SpoolData object consumed by the template parser (Phase 3)
  // Keys match the {token} names used in designer templates.
  function buildSpoolData() {
    return buildSpoolDataFromFlatLabel({
      id: labelData.id,
      filament_id: labelData.filament_id,
      designation: labelData.designation,
      manufacturer: labelData.manufacturer,
      manufacturer_id: labelData.manufacturer_id || labelData.mfr_id,
      type: labelData.type,
      subtype: labelData.subtype,
      color: labelData.color,
      colors: labelData.colors,
      hex_code: labelData.hex_code,
      color_hexes: labelData.color_hexes,
      color_mode: labelData.color_mode,
      multi_color_style: labelData.multi_color_style,
      extruder_temp: labelData.extruder_temp,
      bed_temp: labelData.bed_temp,
      raw_material_weight_g: labelData.raw_material_weight_g,
      weight: labelData.weight,
      diameter: labelData.diameter,
      finish: labelData.finish,
      density: labelData.density,
      price: labelData.price,
      manufacturer_color_name: labelData.manufacturer_color_name,
      default_spool_weight_g: labelData.default_spool_weight_g,
      spool_outer_diameter_mm: labelData.spool_outer_diameter_mm,
      spool_width_mm: labelData.spool_width_mm,
      spool_material: labelData.spool_material,
      shop_url: labelData.shop_url,
      lot_number: labelData.lot_number,
      external_id: labelData.external_id,
      rfid_uid: labelData.rfid_uid,
      location: labelData.location,
      status: labelData.status,
      purchase_date: labelData.purchase_date,
      purchase_price: labelData.purchase_price,
      remaining_weight_g: labelData.remaining_weight_g,
      initial_total_weight_g: labelData.initial_total_weight_g,
      empty_spool_weight_g: labelData.empty_spool_weight_g,
      low_weight_threshold_g: labelData.low_weight_threshold_g,
      stocked_in_at: labelData.stocked_in_at,
      last_used_at: labelData.last_used_at,
      extraFields,
    })
  }

  // DOM references
  const widthInput = document.getElementById('input-width') as HTMLInputElement
  const heightInput = document.getElementById('input-height') as HTMLInputElement
  const fontSizeInput = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput = document.getElementById('input-qr-size') as HTMLInputElement
  const checkLogo = document.getElementById('check-logo') as HTMLInputElement
  const checkQR = document.getElementById('check-qr') as HTMLInputElement
  const checkID = document.getElementById('check-id') as HTMLInputElement
  const checkMfr = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat = document.getElementById('check-mat') as HTMLInputElement
  const checkColor = document.getElementById('check-color') as HTMLInputElement
  const checkColorSwatch = document.getElementById('check-color-swatch') as HTMLInputElement
  const checkColorHex = document.getElementById('check-color-hex') as HTMLInputElement
  const exportPngBtn = document.getElementById('btn-export-png') as HTMLButtonElement
  const exportPdfBtn = document.getElementById('btn-export-pdf') as HTMLButtonElement
  const labelPreview = document.getElementById('label-preview') as HTMLElement

  const LABEL_SETTINGS_KEY = 'filaman-label-settings'
  const ACTIVE_TAB_KEY = 'filaman-label-active-tab'
  const DESIGNER_PRESETS_KEY = 'filaman-spool-label-presets-v1'
  const DESIGNER_SETTINGS_KEY = 'filaman-spool-label-designer-v1'

  // --- Tab switching ---
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  const tabPanelPrint = document.getElementById('tab-panel-print') as HTMLElement | null
  const tabPanelDesigner = document.getElementById('tab-panel-designer') as HTMLElement | null
  const resetBtn = document.getElementById('btn-reset') as HTMLButtonElement | null
  let activePreviewTab: PrintDesignerTab = readPrintDesignerTab(ACTIVE_TAB_KEY)
  let previewRenderVersion = 0

  function beginPreviewRender(tab: 'print' | 'designer') {
    activePreviewTab = tab
    const token = ++previewRenderVersion
    return () => activePreviewTab !== tab || token !== previewRenderVersion
  }

  function renderActiveTab(tab: PrintDesignerTab) {
    if (!tabPanelPrint || !tabPanelDesigner || !labelPreview) return
    if (tab === 'designer') {
      const isStale = beginPreviewRender('designer')
      // Clear any classic preview remnants before building designer layout
      labelPreview.innerHTML = ''
      labelPreview.style.border = ''
      labelPreview.style.padding = ''
      updateDesignerPreview(isStale)
    } else {
      const isStale = beginPreviewRender('print')
      // Force reset of classic layout detection before building print preview
      labelPreview.innerHTML = ''
      labelPreview.style.border = 'none'
      labelPreview.style.padding = ''
      updatePreview(isStale)
    }
  }

  const tabControls = bindPrintDesignerTabs({
    buttons: tabBtns,
    printPanel: tabPanelPrint!,
    designerPanel: tabPanelDesigner!,
    resetButton: resetBtn,
    sidebar: document.querySelector<HTMLElement>('.print-sidebar'),
    storageKey: ACTIVE_TAB_KEY,
    initialTab: activePreviewTab,
    onChange: tab => {
      activePreviewTab = tab
      renderActiveTab(tab)
    },
  })

  // Restore last active tab — deferred until after designer setup completes
  const savedTab = readStorageValue(ACTIVE_TAB_KEY)

  // ─── Label Designer ────────────────────────────────────────────────────────

  const designerEditor = initLabelDesignerEditor({
    extraFields,
    entityType: 'spool',
    getFilamentColorHex: () => labelData.hex_code,
    getFilamentColorHexes: () => labelData.color_hexes,
    getFilamentMultiColorStyle: () => labelData.multi_color_style,
    safeSetLocalStorage,
    translate,
    onChange: () => updateDesignerPreview(),
    presetsKey: DESIGNER_PRESETS_KEY,
    settingsKey: DESIGNER_SETTINGS_KEY,
    entityLabel: 'Spool',
    crossPresetsKey: 'filaman-filament-label-presets-v1',
    ownPresetsLabel: translate('spools.dsPresetsOwnGroup', 'Spool presets'),
    crossPresetsLabel: translate('spools.dsPresetsCrossGroupFilament', 'Filament presets'),
  })

  // ─── Preview zoom ─────────────────────────────────────────────────────────

  const ZOOM_KEY = 'filaman-label-zoom-v1'
  const setZoomTitle = (id: string, key: string, fallback: string) => {
    const button = document.getElementById(id)
    if (!button) return
    const label = translate(key, fallback)
    button.title = label
    button.setAttribute('aria-label', label)
  }
  setZoomTitle('preview-zoom-out', 'labelPrint.zoomOut', 'Zoom out')
  setZoomTitle('preview-zoom-in', 'labelPrint.zoomIn', 'Zoom in')
  setZoomTitle('preview-zoom-reset', 'labelPrint.zoomReset', 'Reset zoom')
  let _previewZoom = 100
  function applyZoom(z: number) {
    _previewZoom = Math.min(300, Math.max(50, Math.round(z / 5) * 5))
    const lp = document.getElementById('label-preview') as HTMLElement
    if (lp) { lp.style.transform = `scale(${_previewZoom / 100})`; lp.style.transformOrigin = 'center center' }
    ;(document.getElementById('preview-zoom-slider') as HTMLInputElement).value = String(_previewZoom)
    const label = document.getElementById('preview-zoom-label')
    if (label) label.textContent = _previewZoom + '%'
    writeStorageValue(ZOOM_KEY, String(_previewZoom))
  }
  document.getElementById('preview-zoom-slider')?.addEventListener('input', (e) => {
    applyZoom(Number((e.target as HTMLInputElement).value))
  })
  document.getElementById('preview-zoom-in')?.addEventListener('click', () => applyZoom(_previewZoom + 10))
  document.getElementById('preview-zoom-out')?.addEventListener('click', () => applyZoom(_previewZoom - 10))
  document.getElementById('preview-zoom-reset')?.addEventListener('click', () => applyZoom(100))
  // Restore persisted zoom level
  ;(() => { const z = Number(readStorageValue(ZOOM_KEY)); if (z >= 50 && z <= 300) applyZoom(z) })()


  // Label logo state
  let labelLogoUrl: string | null = null
  let labelLogoLoaded = false

  // Try to load the manufacturer's label-logo
  async function loadLabelLogo() {
    if (!labelData.mfr_id) return
    try {
      const resp = await fetch(`/api/v1/manufacturers/${labelData.mfr_id}/label-logo`, {
        credentials: 'include',
      })
      if (resp.ok) {
        const blob = await resp.blob()
        labelLogoUrl = URL.createObjectURL(blob)
        labelLogoLoaded = true
      }
    } catch {
      // Label logo not available — fall back to manufacturer name text
    }
  }

  // Build extra field checkboxes dynamically
  const extraFieldsTitle = document.getElementById('title-extra-fields')!
  const extraFieldsCheckboxes = document.getElementById('extra-fields-checkboxes')!
  const extraFieldChecks: {key: string, label: string, value: string, checkbox: HTMLInputElement}[] = []

  let savedExtraFieldSettings: Record<string, boolean> = {}
  const parsedClassicSettings = parseJsonOrNull<SavedLabelSettings>(readStorageValue(LABEL_SETTINGS_KEY))
  if (parsedClassicSettings?.extraFields && typeof parsedClassicSettings.extraFields === 'object') {
    savedExtraFieldSettings = parsedClassicSettings.extraFields as Record<string, boolean>
  }

  if (extraFields.length > 0) {
    extraFieldsTitle.style.display = ''
    extraFieldsCheckboxes.style.display = ''
    const hasBothSources = extraFields.some(ef => ef.source === 'spool') && extraFields.some(ef => ef.source === 'filament')

    // Copy Astro scoped-style attribute from existing checkboxes so dynamic elements get the same styles
    const scopeAttr = (() => {
      const existing = document.querySelector('.fm-checkbox-group')
      if (!existing) return null
      return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
    })()

    for (const ef of extraFields) {
      const lbl = document.createElement('label')
      lbl.className = 'fm-checkbox-group'
      const cb = document.createElement('input')
      cb.type = 'checkbox'
      cb.id = `check-ef-${ef.key}`
      cb.checked = savedExtraFieldSettings[ef.key] || false
      const span = document.createElement('span')
      span.textContent = hasBothSources ? `${ef.label} (${ef.source === 'spool' ? translate('dashboard.spool', 'Spool') : translate('spools.filament', 'Filament')})` : ef.label
      if (scopeAttr) {
        lbl.setAttribute(scopeAttr.name, '')
        cb.setAttribute(scopeAttr.name, '')
        span.setAttribute(scopeAttr.name, '')
      }
      lbl.appendChild(cb)
      lbl.appendChild(span)
      extraFieldsCheckboxes.appendChild(lbl)
      extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
      cb.addEventListener('change', () => updatePreview())
    }
  }

  function saveSettings() {
    const settings: SavedLabelSettings = {
      width: (widthInput as HTMLInputElement).value,
      height: (heightInput as HTMLInputElement).value,
      fontSize: (fontSizeInput as HTMLInputElement).value,
      qrSize: (qrSizeInput as HTMLInputElement).value,
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showMfr: checkMfr.checked,
      showMat: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      showColorHex: checkColorHex.checked,
      extraFields: extraFieldChecks.reduce((acc, ef) => {
        acc[ef.key] = ef.checkbox.checked
        return acc
      }, {} as Record<string, boolean>)
    }
    safeSetLocalStorage(LABEL_SETTINGS_KEY, JSON.stringify(settings))
  }

  function loadSettings() {
    const s = parseJsonOrNull<SavedLabelSettings>(readStorageValue(LABEL_SETTINGS_KEY))
    if (!s || typeof s !== 'object') return
    if (s.width !== undefined) widthInput.value = String(s.width)
    if (s.height !== undefined) heightInput.value = String(s.height)
    if (s.fontSize !== undefined) fontSizeInput.value = String(s.fontSize)
    if (s.qrSize !== undefined) qrSizeInput.value = String(s.qrSize)
    clampInputValue(widthInput, 20, 200, 60, 0)
    clampInputValue(heightInput, 10, 120, 40, 0)
    clampInputValue(fontSizeInput, 50, 200, 100, 0)
    clampInputValue(qrSizeInput, 8, 40, 18, 1)
    if (s.showLogo !== undefined) checkLogo.checked = !!s.showLogo
    if (s.showQR !== undefined) checkQR.checked = !!s.showQR
    if (s.showID !== undefined) checkID.checked = !!s.showID
    if (s.showMfr !== undefined) checkMfr.checked = !!s.showMfr
    if (s.showMat !== undefined) checkMat.checked = !!s.showMat
    if (s.showColor !== undefined) checkColor.checked = !!s.showColor
    if (s.showColorSwatch !== undefined) checkColorSwatch.checked = !!s.showColorSwatch
    if (s.showColorHex !== undefined) checkColorHex.checked = !!s.showColorHex
  }

  loadSettings()

  document.getElementById('tab-btn-print')!.textContent = translate('labelPrint.standardLabel', 'Standard Label')
  document.getElementById('tab-btn-designer')!.textContent = translate('spools.labelDesigner', 'Label Designer')
  document.getElementById('title-settings')!.textContent = translate('labelPrint.settingsTitle', 'Label Settings')

  document.getElementById('label-width-text')!.textContent = translate('spools.labelWidth')
  document.getElementById('label-height-text')!.textContent = translate('spools.labelHeight')
  document.getElementById('label-font-size-text')!.textContent = translate('spools.fontSize')
  document.getElementById('label-qr-size-text')!.textContent = translate('spools.qrSize')
  document.getElementById('label-show-logo')!.textContent = translate('spools.showLogo', 'Logo')
  document.getElementById('label-show-qr')!.textContent = translate('spools.showQRCode')
  document.getElementById('label-show-id')!.textContent = translate('spools.showSpoolId')
  document.getElementById('label-show-mfr')!.textContent = translate('spools.showManufacturer')
  document.getElementById('label-show-mat')!.textContent = translate('spools.showMaterial')
  document.getElementById('label-show-color')!.textContent = translate('spools.showColor')
  document.getElementById('label-show-color-swatch')!.textContent = translate('spools.showColorSwatch', 'Color Swatch')
  document.getElementById('label-show-color-hex')!.textContent = translate('labelPrint.checkColorHex', 'Color Hex')
  if (extraFields.length > 0) {
    document.getElementById('title-extra-fields')!.textContent = translate('spools.extraFieldsLabel')
  }
  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  backBtn.href = `/spools/${id}`
  document.getElementById('label-back')!.textContent = translate('spools.backToSpool')
  exportPngBtn.textContent = translate('labelPrint.btnExportPng', 'Export PNG')
  exportPdfBtn.textContent = translate('labelPrint.btnExportPdf', 'Export PDF')
  document.getElementById('btn-print')!.textContent = translate('common.print')
  document.getElementById('btn-reset')!.textContent = translate('spools.resetDefaults')

  function getSelectedStandardExtraFields(): StandardExtraField[] {
    return extraFieldChecks
      .filter(ef => ef.checkbox.checked)
      .map(ef => ({ label: ef.label, value: ef.value }))
  }

  function getStandardSettings(): StandardLabelSettings {
    return {
      widthMm: clampInputValue(widthInput, 20, 200, 60, 0),
      heightMm: clampInputValue(heightInput, 10, 120, 40, 0),
      fontScale: clampInputValue(fontSizeInput, 50, 200, 100, 0) / 100,
      qrSizeMm: clampInputValue(qrSizeInput, 8, 40, 18, 1),
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showManufacturer: checkMfr.checked,
      showMaterial: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      showColorHex: checkColorHex.checked,
    }
  }

  function buildStandardData() {
    return buildStandardLabelDataFromFlat({
      id: labelData.id,
      designation: labelData.designation,
      manufacturer: labelData.manufacturer,
      material: labelData.type,
      colorName: labelData.color,
      hexCode: labelData.hex_code,
      colorHexes: labelData.color_hexes,
      multiColorStyle: labelData.multi_color_style,
      extraFields: getSelectedStandardExtraFields(),
    })
  }

  async function updatePreview(isStale = () => false) {
    if (activePreviewTab !== 'print') return
    if (isStale() || activePreviewTab !== 'print') return

    labelPreview.style.border = 'none'
    labelPreview.style.padding = ''
    await renderStandardLabel({
      element: labelPreview,
      data: buildStandardData(),
      settings: getStandardSettings(),
      logoUrl: labelLogoLoaded ? labelLogoUrl : null,
      isStale: () => isStale() || activePreviewTab !== 'print',
    })
    if (isStale() || activePreviewTab !== 'print') return
    saveSettings()
  }

  ;[widthInput, heightInput, fontSizeInput, qrSizeInput, checkLogo, checkQR, checkID, checkMfr, checkMat, checkColor, checkColorSwatch, checkColorHex].forEach(el => {
    el.addEventListener('change', () => updatePreview())
    if ((el as HTMLInputElement).type === 'range' || (el as HTMLInputElement).type === 'number') {
      el.addEventListener('input', () => updatePreview())
    }
  })

  // ─── Designer preview ─────────────────────────────────────────────────────

  async function updateDesignerPreview(isStale = () => false) {
    if (activePreviewTab !== 'designer') return
    if (isStale() || activePreviewTab !== 'designer') return

    await renderDesignerLabel({
      element: labelPreview,
      previewBorder: false,
      settings: loadDesignerSettingsFromStorage({
        presetsKey: DESIGNER_PRESETS_KEY,
        settingsKey: DESIGNER_SETTINGS_KEY,
      }),
      data: buildSpoolData(),
      logoUrl: labelLogoLoaded ? labelLogoUrl : null,
      isStale: () => isStale() || activePreviewTab !== 'designer',
    })
  }

  // ─── Export ───────────────────────────────────────────────────────────────

  function buildExportBaseName() {
    const mode = activePreviewTab === 'designer' ? 'designer' : 'classic'
    return buildLabelExportBaseName([
      'spool-label',
      labelData.manufacturer,
      labelData.designation,
      labelData.id ? `spool-${labelData.id}` : '',
      mode,
    ], `spool-label-${mode}`)
  }

  bindSingleLabelExport({
    exportPngBtn,
    exportPdfBtn,
    labelElement: labelPreview,
    pixelRatio: LABEL_EXPORT_PIXEL_RATIO,
    getTranslation: translate,
    buildBaseName: buildExportBaseName,
    getDimensions: () => activePreviewTab === 'designer'
      ? getDesignerLabelDimensions(loadDesignerSettingsFromStorage({
        presetsKey: DESIGNER_PRESETS_KEY,
        settingsKey: DESIGNER_SETTINGS_KEY,
      }))
      : getStandardLabelDimensions(getStandardSettings()),
    refreshPreview: async () => {
      if (activePreviewTab === 'designer') await updateDesignerPreview()
      else await updatePreview()
    },
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    removeStorageValue(LABEL_SETTINGS_KEY);
    (widthInput as HTMLInputElement).value = '60';
    (heightInput as HTMLInputElement).value = '40';
    (fontSizeInput as HTMLInputElement).value = '100';
    (qrSizeInput as HTMLInputElement).value = '18';
    checkLogo.checked = true;
    checkQR.checked = true;
    checkID.checked = true;
    checkMfr.checked = true;
    checkMat.checked = true;
    checkColor.checked = true;
    checkColorSwatch.checked = true;
    checkColorHex.checked = true;
    for (const ef of extraFieldChecks) {
      ef.checkbox.checked = false
    }
    updatePreview()
  })

  const apiSpoolData = await fetchSpoolApiData()

  // Restore active tab now that all designer state is fully initialized
  if (savedTab === 'designer') tabControls.activate('designer')

  // Initialize: load logo then render whichever tab is active
  loadLabelLogo().then(() => {
    tabControls.activate(readPrintDesignerTab(ACTIVE_TAB_KEY))
  })

  // Fallback: if no extra fields came from sessionStorage (e.g. direct navigation),
  // fetch definitions from the API and rebuild the extra-fields UI.
  if (extraFields.length === 0) {
    ;(async () => {
      try {
        const [spoolDefs, filamentDefs] = await Promise.all([
          fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
          fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include' }).then(r => r.ok ? r.json() : []),
        ])
        const allDefs: {key: string, label: string, target_type: string}[] = [
          ...(Array.isArray(spoolDefs) ? spoolDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'spool'})),
          ...(Array.isArray(filamentDefs) ? filamentDefs : []).map((d: {key: string, label: string}) => ({...d, target_type: 'filament'})),
        ]
        if (allDefs.length === 0) return

        // Attempt to get actual spool values
        const spoolCustom: Record<string, string> = {}
        const filamentCustom: Record<string, string> = {}
        const sd = apiSpoolData ?? await fetchSpoolApiData()
        if (sd) {
          if (sd.custom_fields) {
            for (const [k, v] of Object.entries(sd.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) spoolCustom[k] = String(v)
            }
          }
          if (sd.filament?.custom_fields) {
            for (const [k, v] of Object.entries(sd.filament.custom_fields as Record<string, unknown>)) {
              if (v !== null && v !== undefined) filamentCustom[k] = String(v)
            }
          }
        }

        // Populate extraFields and rebuild UI
        const hasBothSources = allDefs.some(d => d.target_type === 'spool') && allDefs.some(d => d.target_type === 'filament')
        const scopeAttr = (() => {
          const existing = document.querySelector('.fm-checkbox-group')
          if (!existing) return null
          return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
        })()

        for (const def of allDefs) {
          const valueMap = def.target_type === 'spool' ? spoolCustom : filamentCustom
          const ef = {
            key: `${def.target_type}.${def.key}`,
            label: def.label,
            value: valueMap[def.key] ?? '',
            source: def.target_type,
          }
          extraFields.push(ef)

          const lbl = document.createElement('label')
          lbl.className = 'fm-checkbox-group'
          const cb = document.createElement('input')
          cb.type = 'checkbox'
          cb.id = `check-ef-${ef.key}`
          cb.checked = savedExtraFieldSettings[ef.key] || false
          const span = document.createElement('span')
          span.textContent = hasBothSources
            ? `${ef.label} (${def.target_type === 'spool' ? translate('dashboard.spool', 'Spool') : translate('spools.filament', 'Filament')})`
            : ef.label
          if (scopeAttr) {
            lbl.setAttribute(scopeAttr.name, '')
            cb.setAttribute(scopeAttr.name, '')
            span.setAttribute(scopeAttr.name, '')
          }
          lbl.appendChild(cb)
          lbl.appendChild(span)
          extraFieldsCheckboxes.appendChild(lbl)
          extraFieldChecks.push({ key: ef.key, label: ef.label, value: ef.value, checkbox: cb })
          cb.addEventListener('change', () => updatePreview())
        }

        // Show the print-settings extra-fields section
        extraFieldsTitle.style.display = ''
        extraFieldsCheckboxes.style.display = ''
        document.getElementById('title-extra-fields')!.textContent = translate('spools.extraFieldsLabel', 'Spool Extra Fields')

        // Rebuild token areas in the designer so extra-field chips appear.
        designerEditor.refreshExtraFields(extraFields)

        updatePreview()
      } catch { /* ignore */ }
    })()
  }
</script>
