---
import Layout from '../../layouts/Layout.astro'
import LabelDesignerEditor from '../../components/LabelDesignerEditor.astro'
import StandardLabelSettingsPanel from '../../components/StandardLabelSettingsPanel.astro'
import BatchLabelPrintStyles from '../../components/BatchLabelPrintStyles.astro'
---

<Layout title="FilaMan - Label Print">
  <BatchLabelPrintStyles />

  <div class="print-page">
    <aside class="print-sidebar">
      <a id="btn-back" href="/spools" class="sidebar-header back-link">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M19 12H5"/><path d="m12 19-7-7 7-7"/></svg>
        <span id="btn-back-label" data-i18n="labelPrint.backToOverview">Back to Overview</span>
      </a>

      <div class="tab-nav">
        <button class="tab-btn active" id="tab-btn-print" data-tab="print" data-i18n="labelPrint.standardLabel">Standard Label</button>
        <button class="tab-btn" id="tab-btn-designer" data-tab="designer" data-i18n="spools.labelDesigner">Label Designer</button>
      </div>

      <StandardLabelSettingsPanel
        idLabelI18n="labelPrint.checkId"
        idFallback="Spool ID"
        includeSpoolFields
        extraFieldsMode="batch"
      />

      <LabelDesignerEditor />

      <div class="action-buttons">
        <div class="export-buttons">
          <button id="btn-export-png" class="fm-btn fm-btn-outline" onclick="filamanExportPNG()" data-i18n="labelPrint.btnExportPng">Export PNG</button>
          <button id="btn-export-pdf" class="fm-btn fm-btn-outline" onclick="filamanExportPDF()" data-i18n="labelPrint.btnExportPdf">Export PDF</button>
        </div>
        <button class="fm-btn fm-btn-primary" onclick="filamanPrint()" data-i18n="labelPrint.btnPrint">Print</button>
        <button id="btn-reset" class="fm-btn fm-btn-outline" data-i18n="labelPrint.btnReset">Reset</button>
      </div>
    </aside>

    <main class="preview-container" id="preview-container">
      <div class="preview-zoom-bar">
        <button class="preview-zoom-btn" id="preview-zoom-out" title="Zoom out" aria-label="Zoom out">−</button>
        <input type="range" id="preview-zoom-slider" min="25" max="300" step="5" value="100" class="preview-zoom-slider">
        <button class="preview-zoom-btn" id="preview-zoom-in" title="Zoom in" aria-label="Zoom in">+</button>
        <span id="preview-zoom-label" class="preview-zoom-label">100%</span>
        <button class="preview-zoom-btn" id="preview-zoom-reset" title="Reset zoom" aria-label="Reset zoom">⟳</button>
      </div>
      <div class="label-count" id="label-count"></div>
    </main>
  </div>
</Layout>

<script>
  import { initLabelDesignerEditor } from '../../lib/label-designer-editor'
  import {
    buildDesignerExtraFieldsFromApiSpool,
    buildSpoolDataFromApiSpool,
    clampNumber,
    getFirstFilamentColor,
    getDesignerLabelDimensions,
    getManufacturerIdFromApiSpool,
    loadDesignerSettingsFromStorage,
    renderDesignerLabel,
    type DesignerExtraField,
  } from '../../lib/label-designer'
  import {
    buildStandardLabelDataFromApiSpool,
    buildStandardLabelHtml,
    getStandardLabelDimensions,
    renderStandardLabel,
    type StandardLabelSettings,
  } from '../../lib/label-standard'
  import {
    bindBatchLabelExport,
    captureBatchLabel,
    findBatchLabelElement,
    getCachedEntityLogoUrl,
    makeBatchLabelHtml,
    bindPrintDesignerTabs,
    bindPreviewZoomControls,
    installPrintFunction,
    prefetchEntityLogos,
    readPrintDesignerTab,
    readStorageValue,
    removeStorageValue,
    type LabelPrintEntityAdapter,
    type PrintDesignerTab,
    writeStorageValue,
  } from '../../lib/label-print-page'
  import { isBuiltInLabelField } from '../../lib/label-extra-fields'
  import { t, initI18n } from '../../lib/i18n'

  installPrintFunction()

  const SETTINGS_KEY = 'filaman-label-settings'
  const DESIGNER_PRESETS_KEY = 'filaman-spool-label-presets-v1'
  const DESIGNER_SETTINGS_KEY = 'filaman-spool-label-designer-v1'

  const widthInput   = document.getElementById('input-width') as HTMLInputElement
  const heightInput  = document.getElementById('input-height') as HTMLInputElement
  const fontInput    = document.getElementById('input-font-size') as HTMLInputElement
  const qrSizeInput  = document.getElementById('input-qr-size') as HTMLInputElement
  const checkLogo    = document.getElementById('check-logo') as HTMLInputElement
  const checkQR      = document.getElementById('check-qr') as HTMLInputElement
  const checkID      = document.getElementById('check-id') as HTMLInputElement
  const checkMfr     = document.getElementById('check-mfr') as HTMLInputElement
  const checkMat     = document.getElementById('check-mat') as HTMLInputElement
  const checkColor   = document.getElementById('check-color') as HTMLInputElement
  const checkColorSwatch = document.getElementById('check-color-swatch') as HTMLInputElement
  const checkColorHex = document.getElementById('check-color-hex') as HTMLInputElement
  const zoomInput    = document.createElement('input')
  zoomInput.type = 'hidden'
  zoomInput.value = '100'
  const previewZoomSlider = document.getElementById('preview-zoom-slider') as HTMLInputElement | null
  const previewZoomLabel = document.getElementById('preview-zoom-label') as HTMLElement | null
  const tabBtns = document.querySelectorAll<HTMLButtonElement>('.tab-btn')
  const tabPanelPrint = document.getElementById('tab-panel-print') as HTMLElement
  const tabPanelDesigner = document.getElementById('tab-panel-designer') as HTMLElement
  const resetBtn = document.getElementById('btn-reset') as HTMLButtonElement | null
  const exportPngBtn = document.getElementById('btn-export-png') as HTMLButtonElement
  const exportPdfBtn = document.getElementById('btn-export-pdf') as HTMLButtonElement

  type ExtraFieldDef = { key: string; label: string; target_type: 'spool' | 'filament' }
  type ApiObject = Record<string, unknown>
  type ApiFilament = ApiObject & { custom_fields?: Record<string, unknown> }
  type ApiSpool = ApiObject & {
    id?: string | number
    custom_fields?: Record<string, unknown>
    filament?: ApiFilament
    location?: { label?: unknown; name?: unknown }
    status?: { label?: unknown }
  }

  let spools: ApiSpool[] = []
  type SpoolLabelEntity = ApiSpool
  const logoCache: Record<number, string | null> = {}
  let activePreviewTab: PrintDesignerTab = readPrintDesignerTab('filaman-label-active-tab')
  let renderVersion = 0

  // Extra field definitions from API: {key, label, target_type}
  let efDefs: ExtraFieldDef[] = []
  // Per-field checkbox state: key -> {checkbox, checked}
  const efCheckMap: Record<string, HTMLInputElement> = {}

  function efMapKey(targetType: string, key: string): string {
    return `${targetType}:${key}`
  }

  function isApiObject(value: unknown): value is ApiObject {
    return typeof value === 'object' && value !== null
  }

  function isExtraFieldDef(value: unknown): value is { key: string; label: string } {
    return isApiObject(value) && typeof value.key === 'string' && typeof value.label === 'string'
  }

  function normalizeExtraFieldDefs(value: unknown, targetType: ExtraFieldDef['target_type']): ExtraFieldDef[] {
    const items = Array.isArray(value)
      ? value
      : isApiObject(value) && Array.isArray(value.items)
        ? value.items
        : []
    return items
      .filter(isExtraFieldDef)
      .map(def => ({ key: def.key, label: def.label, target_type: targetType }))
  }

  function saveSettings() {
    const efState: Record<string, boolean> = {}
    Object.entries(efCheckMap).forEach(([k, cb]) => { efState[k] = cb.checked })
    writeStorageValue(SETTINGS_KEY, JSON.stringify({
      width: widthInput.value, height: heightInput.value,
      fontSize: fontInput.value, qrSize: qrSizeInput.value,
      showLogo: checkLogo.checked, showQR: checkQR.checked, showID: checkID.checked,
      showMfr: checkMfr.checked, showMat: checkMat.checked,
      showColor: checkColor.checked, showColorSwatch: checkColorSwatch.checked, showColorHex: checkColorHex.checked,
      zoom: zoomInput.value, extraFields: efState,
    }))
  }

  function loadSettings() {
    try {
      const s = JSON.parse(readStorageValue(SETTINGS_KEY) || 'null')
      if (!s) return
      if (s.width) widthInput.value = s.width
      if (s.height) heightInput.value = s.height
      if (s.fontSize) fontInput.value = s.fontSize
      if (s.qrSize) qrSizeInput.value = s.qrSize
      if (s.showLogo !== undefined) checkLogo.checked = s.showLogo
      if (s.showQR !== undefined) checkQR.checked = s.showQR
      if (s.showID !== undefined) checkID.checked = s.showID
      if (s.showMfr !== undefined) checkMfr.checked = s.showMfr
      if (s.showMat !== undefined) checkMat.checked = s.showMat
      if (s.showColor !== undefined) checkColor.checked = s.showColor
      if (s.showColorSwatch !== undefined) checkColorSwatch.checked = s.showColorSwatch
      if (s.showColorHex !== undefined) checkColorHex.checked = s.showColorHex
      if (s.zoom !== undefined) zoomInput.value = s.zoom
      if (s.extraFields) {
        Object.entries(s.extraFields as Record<string, boolean>).forEach(([k, v]) => {
          if (efCheckMap[k]) efCheckMap[k].checked = v
        })
      }
      previewZoomControls.sync()
    } catch {}
  }

  async function loadLogo(mfrId: number): Promise<string | null> {
    if (mfrId in logoCache) return logoCache[mfrId]
    try {
      const r = await fetch(`/api/v1/manufacturers/${mfrId}/label-logo`, { credentials: 'include' })
      if (r.ok) {
        const blob = await r.blob()
        const dataUrl = await new Promise<string>((res) => {
          const reader = new FileReader()
          reader.onload = () => res(reader.result as string)
          reader.readAsDataURL(blob)
        })
        logoCache[mfrId] = dataUrl; return dataUrl
      }
    } catch {}
    logoCache[mfrId] = null; return null
  }

  function getBatchDesignerExtraFields(): DesignerExtraField[] {
    const fields = new Map<string, DesignerExtraField>()
    for (const def of efDefs) {
      const key = `${def.target_type}.${def.key}`
      fields.set(key, { key, label: def.label, value: '', source: def.target_type })
    }
    for (const spool of spools) {
      for (const field of buildDesignerExtraFieldsFromApiSpool(spool)) {
        if (!field?.key || fields.has(field.key)) continue
        fields.set(field.key, field)
      }
    }
    return Array.from(fields.values())
  }

  function getBatchFilamentColorData() {
    for (const spool of spools) {
      const filament = spool?.filament
      const firstColor = getFirstFilamentColor(filament)
      const hex = typeof firstColor?.color?.hex_code === 'string' ? firstColor.color.hex_code : ''
      const colors = Array.isArray(filament?.colors) ? filament.colors : []
      const colorHexes = colors
        .map(color => {
          const colorData = typeof color === 'object' && color !== null
            ? (color as { color?: { hex_code?: unknown } }).color
            : null
          return typeof colorData?.hex_code === 'string' ? colorData.hex_code : ''
        })
        .filter(Boolean)
        .join(', ')
      if (hex || colorHexes) {
        return {
          hex,
          colorHexes,
          multiColorStyle: typeof filament?.multi_color_style === 'string' ? filament.multi_color_style : '',
        }
      }
    }
    return null
  }

  function getExtraFieldsForSpool(spool: ApiSpool): {key: string, label: string, value: string}[] {
    const result: {key: string, label: string, value: string}[] = []

    // ── Spool model field checkboxes (shown when checked in sidebar) ──────
    const fmtDate = (raw: unknown) => raw ? new Date(String(raw)).toLocaleDateString() : ''
    const modelFields: [string, string, unknown][] = [
      ['lot_number',             'Lot Number',              spool.lot_number],
      ['external_id',            'External ID',             spool.external_id],
      ['rfid_uid',               'RFID UID',                spool.rfid_uid],
      ['location',               'Location',                spool.location?.label ?? spool.location?.name],
      ['status',                 'Status',                  spool.status?.label],
      ['purchase_date',          'Purchase Date',           fmtDate(spool.purchase_date)],
      ['purchase_price',         'Purchase Price',          spool.purchase_price],
      ['remaining_weight_g',     'Remaining Weight (g)',    spool.remaining_weight_g],
      ['initial_total_weight_g', 'Initial Weight (g)',      spool.initial_total_weight_g],
      ['empty_spool_weight_g',   'Empty Spool Weight (g)',  spool.empty_spool_weight_g],
      ['low_weight_threshold_g', 'Low Weight Threshold (g)',spool.low_weight_threshold_g],
      ['stocked_in_at',          'Stocked In',              fmtDate(spool.stocked_in_at)],
      ['last_used_at',           'Last Used',               fmtDate(spool.last_used_at)],
    ]
    for (const [key, label, rawVal] of modelFields) {
      const cb = efCheckMap[`model:${key}`]
      if (!cb?.checked) continue
      const val = rawVal !== undefined && rawVal !== null ? String(rawVal) : ''
      if (val) result.push({ key, label, value: val })
    }

    for (const def of efDefs) {
      const cb = efCheckMap[efMapKey(def.target_type, def.key)]
      if (!cb?.checked) continue

      let val: string | null = null
      if (def.target_type === 'spool' && spool.custom_fields) {
        const raw = spool.custom_fields[def.key]
        if (raw !== undefined && raw !== null) val = String(raw)
      } else if (def.target_type === 'filament' && spool.filament?.custom_fields) {
        const raw = spool.filament.custom_fields[def.key]
        if (raw !== undefined && raw !== null) val = String(raw)
      }
      if (val !== null) result.push({ key: def.key, label: def.label, value: val })
    }
    return result
  }

  function getStandardSettings(): StandardLabelSettings {
    return {
      widthMm: clampNumber(Number(widthInput.value), 20, 200, 60),
      heightMm: clampNumber(Number(heightInput.value), 10, 120, 40),
      fontScale: clampNumber(parseInt(fontInput.value), 50, 200, 100) / 100,
      qrSizeMm: clampNumber(Number(qrSizeInput.value), 8, 40, 18),
      showLogo: checkLogo.checked,
      showQR: checkQR.checked,
      showID: checkID.checked,
      showManufacturer: checkMfr.checked,
      showMaterial: checkMat.checked,
      showColor: checkColor.checked,
      showColorSwatch: checkColorSwatch.checked,
      showColorHex: checkColorHex.checked,
      zoom: (parseInt(zoomInput.value) || 100) / 100,
    }
  }

  function datedExportName(prefix: string, extension: string) {
    return `${prefix}-${new Date().toISOString().slice(0, 10)}.${extension}`
  }

  const labelAdapter = {
    entityType: 'spool',
    entityPath: 'spools',
    getId: spool => spool?.id,
    getLogoManufacturerId: getManufacturerIdFromApiSpool,
    buildStandardData: spool => buildStandardLabelDataFromApiSpool(spool, getExtraFieldsForSpool(spool)),
    buildDesignerData: buildSpoolDataFromApiSpool,
    singlePngName: spool => `label-${spool.id}.png`,
    zipName: () => datedExportName('labels', 'zip'),
    zipEntryName: spool => `label-${spool.id}.png`,
    pdfName: () => datedExportName('labels', 'pdf'),
    missingIdMessage: 'Cannot capture label: spool is missing an id',
  } satisfies LabelPrintEntityAdapter<SpoolLabelEntity>

  async function renderLabel(container: HTMLElement, spool: ApiSpool, isStale = () => false) {
    await renderStandardLabel({
      element: container,
      data: labelAdapter.buildStandardData(spool),
      settings: getStandardSettings(),
      logoUrl: getCachedEntityLogoUrl(labelAdapter, logoCache, spool),
      isStale,
    })
  }

  async function renderDesignerLabelForSpool(container: HTMLElement, spool: ApiSpool, isStale = () => false) {
    const settings = loadDesignerSettingsFromStorage({
      presetsKey: DESIGNER_PRESETS_KEY,
      settingsKey: DESIGNER_SETTINGS_KEY,
    })
    const zoom = parseInt(zoomInput.value) / 100
    container.style.zoom = String(zoom)
    await renderDesignerLabel({
      element: container,
      previewBorder: false,
      settings,
      data: labelAdapter.buildDesignerData(spool),
      logoUrl: getCachedEntityLogoUrl(labelAdapter, logoCache, spool),
      isStale,
      entityPath: labelAdapter.entityPath,
    })
  }

  function makeLabelHtml(spoolId: number): string {
    return makeBatchLabelHtml(spoolId, buildStandardLabelHtml())
  }

  async function prefetchLogos() {
    await prefetchEntityLogos(spools, labelAdapter, loadLogo)
  }

  // Render labels in parallel chunks so the browser stays responsive
  async function renderAll(tab: 'print' | 'designer' = activePreviewTab) {
    const token = ++renderVersion
    const isStale = () => token !== renderVersion || activePreviewTab !== tab
    const CHUNK = 6
    for (let i = 0; i < spools.length; i += CHUNK) {
      if (isStale()) return
      const chunk = spools.slice(i, i + CHUNK)
      await Promise.all(chunk.map(spool => {
        const el = findBatchLabelElement(labelAdapter, spool)
        if (!el) return Promise.resolve()
        return tab === 'designer'
          ? renderDesignerLabelForSpool(el, spool, isStale)
          : renderLabel(el, spool, isStale)
      }))
      if (isStale()) return
      // Yield to browser between chunks
      await new Promise(r => setTimeout(r, 0))
    }
    if (isStale()) return
    saveSettings()
  }

  function queueRenderAll() {
    void renderAll()
  }

  async function loadExtraFieldDefs() {
    try {
      const [spoolDefs, filamentDefs] = await Promise.all([
        fetch('/api/v1/system-extra-fields?target_type=spool', { credentials: 'include' }).then(r => r.json()),
        fetch('/api/v1/system-extra-fields?target_type=filament', { credentials: 'include' }).then(r => r.json()),
      ])
      const allDefs = [
        ...normalizeExtraFieldDefs(spoolDefs, 'spool'),
        ...normalizeExtraFieldDefs(filamentDefs, 'filament'),
      ].filter(def => !isBuiltInLabelField(def.target_type, def.key, def.label))
      if (allDefs.length === 0) return

      efDefs = allDefs
      const titleEl = document.getElementById('ef-section-title')!
      const container = document.getElementById('ef-checkboxes')!
      // Copy Astro scope attribute so scoped CSS applies to dynamic elements
      const scopeAttr = (() => {
        const existing = document.querySelector('.fm-checkbox-group')
        if (!existing) return null
        return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
      })()

      const extraFieldGroups = new Map<string, { title: HTMLElement; container: HTMLElement }>()
      let lastExtraFieldGroupNode: Element = container

      function getExtraFieldSource(source?: string) {
        return source === 'filament' ? 'filament' : 'spool'
      }

      function getExtraFieldGroupTitle(source: string) {
        return source === 'filament'
          ? (t('filaments.extraFieldsLabel') || 'Filament Extra Fields')
          : (t('spools.extraFieldsLabel') || 'Spool Extra Fields')
      }

      function getExtraFieldGroup(source?: string) {
        const normalizedSource = getExtraFieldSource(source)
        const existing = extraFieldGroups.get(normalizedSource)
        if (existing) return existing

        const titleText = getExtraFieldGroupTitle(normalizedSource)
        if (extraFieldGroups.size === 0) {
          titleEl.textContent = titleText
          titleEl.style.display = ''
          container.style.removeProperty('display')
          const group = { title: titleEl as HTMLElement, container: container as HTMLElement }
          extraFieldGroups.set(normalizedSource, group)
          return group
        }

        const title = document.createElement('h3')
        title.textContent = titleText
        const groupContainer = document.createElement('div')
        groupContainer.className = container.className
        groupContainer.style.removeProperty('display')
        lastExtraFieldGroupNode.insertAdjacentElement('afterend', title)
        title.insertAdjacentElement('afterend', groupContainer)
        lastExtraFieldGroupNode = groupContainer
        const group = { title, container: groupContainer }
        extraFieldGroups.set(normalizedSource, group)
        return group
      }

      for (const def of allDefs) {
        const group = getExtraFieldGroup(def.target_type)
        const row = document.createElement('label')
        row.className = 'fm-checkbox-group'
        const cb = document.createElement('input'); cb.type = 'checkbox'; cb.checked = false
        const span = document.createElement('span')
        span.textContent = def.label
        if (scopeAttr) { row.setAttribute(scopeAttr.name, ''); cb.setAttribute(scopeAttr.name, ''); span.setAttribute(scopeAttr.name, '') }
        row.appendChild(cb); row.appendChild(span)
        group.container.appendChild(row)
        efCheckMap[efMapKey(def.target_type, def.key)] = cb
        cb.addEventListener('change', queueRenderAll)
      }
    } catch {}
  }

  // ── Export helpers ────────────────────────────────────────────────────────

  async function captureLabel(spool: ApiSpool): Promise<string> {
    return captureBatchLabel(labelAdapter, spool)
  }

  // ── Init ──────────────────────────────────────────────────────────────────

  await initI18n()
  function tFallback(key: string, fallback: string): string {
    const value = t(key)
    return value && value !== key ? value : fallback
  }
  const zoomOutBtn = document.getElementById('preview-zoom-out') as HTMLButtonElement | null
  const zoomInBtn = document.getElementById('preview-zoom-in') as HTMLButtonElement | null
  const zoomResetBtn = document.getElementById('preview-zoom-reset') as HTMLButtonElement | null
  const previewZoomControls = bindPreviewZoomControls({
    zoomInput,
    slider: previewZoomSlider,
    label: previewZoomLabel,
    zoomOutBtn,
    zoomInBtn,
    zoomResetBtn,
    getTranslation: (key, fallback) => t(key) || fallback,
    onChange: queueRenderAll,
  })

  const designerEditor = initLabelDesignerEditor({
    extraFields: [],
    entityType: labelAdapter.entityType,
    getFilamentColorHex: () => getBatchFilamentColorData()?.hex || '',
    getFilamentColorHexes: () => getBatchFilamentColorData()?.colorHexes || '',
    getFilamentMultiColorStyle: () => getBatchFilamentColorData()?.multiColorStyle || '',
    translate: (key, fallback) => t(key) || fallback,
    onChange: queueRenderAll,
    presetsKey: DESIGNER_PRESETS_KEY,
    settingsKey: DESIGNER_SETTINGS_KEY,
    entityLabel: 'Spool',
    crossPresetsKey: 'filaman-filament-label-presets-v1',
    ownPresetsLabel: (t('spools.dsPresetsOwnGroup') || 'Spool presets'),
    crossPresetsLabel: (t('spools.dsPresetsCrossGroupFilament') || 'Filament presets'),
  })

  const getCurrentLabelDimensions = () => {
    if (activePreviewTab === 'designer') {
      return getDesignerLabelDimensions(loadDesignerSettingsFromStorage({
        presetsKey: DESIGNER_PRESETS_KEY,
        settingsKey: DESIGNER_SETTINGS_KEY,
      }))
    }
    return getStandardLabelDimensions(getStandardSettings())
  }

  const tabControls = bindPrintDesignerTabs({
    buttons: tabBtns,
    printPanel: tabPanelPrint,
    designerPanel: tabPanelDesigner,
    resetButton: resetBtn,
    sidebar: document.querySelector<HTMLElement>('.print-sidebar'),
    storageKey: 'filaman-label-active-tab',
    initialTab: activePreviewTab,
    onChange: tab => {
      activePreviewTab = tab
      queueRenderAll()
    },
  })

  bindBatchLabelExport({
    entities: () => spools,
    activeTab: () => activePreviewTab,
    pngButton: exportPngBtn,
    pdfButton: exportPdfBtn,
    getTranslation: (key, fallback) => t(key) || fallback,
    renderAll,
    captureLabel,
    getPdfDimensions: getCurrentLabelDimensions,
    singlePngName: labelAdapter.singlePngName,
    zipName: labelAdapter.zipName,
    zipEntryName: labelAdapter.zipEntryName,
    pdfName: labelAdapter.pdfName,
  })

  // ── Spool model field checkboxes ─────────────────────────────────────────
  ;(function buildSpoolModelCheckboxes() {
    const container = document.getElementById('spool-model-checkboxes')!
    const savedState = (() => {
      try { return JSON.parse(readStorageValue('filaman-spool-model-field-checks') || 'null') } catch { return null }
    })() as Record<string, boolean> | null
    const scopeAttr = (() => {
      const existing = document.querySelector('.fm-checkbox-group')
      if (!existing) return null
      return Array.from(existing.attributes).find(a => a.name.startsWith('data-astro-cid-'))
    })()
    const modelFieldDefs: [string, string][] = [
      ['lot_number',             tFallback('labelPrint.fieldLotNumber', 'Lot Number')],
      ['external_id',            tFallback('labelPrint.fieldExternalId', 'External ID')],
      ['rfid_uid',               tFallback('labelPrint.fieldRfidUid', 'RFID UID')],
      ['location',               tFallback('labelPrint.fieldLocation', 'Location')],
      ['status',                 tFallback('labelPrint.fieldStatus', 'Status')],
      ['purchase_date',          tFallback('labelPrint.fieldPurchaseDate', 'Purchase Date')],
      ['purchase_price',         tFallback('labelPrint.fieldPurchasePrice', 'Purchase Price')],
      ['remaining_weight_g',     tFallback('labelPrint.fieldRemainingWt', 'Remaining Weight (g)')],
      ['initial_total_weight_g', tFallback('labelPrint.fieldInitialWt', 'Initial Weight (g)')],
      ['empty_spool_weight_g',   tFallback('labelPrint.fieldEmptySpoolWt', 'Empty Spool Weight (g)')],
      ['low_weight_threshold_g', tFallback('labelPrint.fieldLowWeightThreshold', 'Low Weight Threshold (g)')],
      ['stocked_in_at',          tFallback('labelPrint.fieldStockedIn', 'Stocked In')],
      ['last_used_at',           tFallback('labelPrint.fieldLastUsed', 'Last Used')],
    ]
    for (const [key, label] of modelFieldDefs) {
      const row = document.createElement('label')
      row.className = 'fm-checkbox-group'
      const cb = document.createElement('input'); cb.type = 'checkbox'; cb.checked = savedState?.[key] ?? false
      const span = document.createElement('span'); span.textContent = label
      if (scopeAttr) { row.setAttribute(scopeAttr.name, ''); cb.setAttribute(scopeAttr.name, ''); span.setAttribute(scopeAttr.name, '') }
      row.appendChild(cb); row.appendChild(span)
      container.appendChild(row)
      efCheckMap[`model:${key}`] = cb
      cb.addEventListener('change', () => {
        try {
          const state: Record<string, boolean> = {}
          for (const [k] of modelFieldDefs) { const c = efCheckMap[`model:${k}`]; if (c) state[k] = c.checked }
          writeStorageValue('filaman-spool-model-field-checks', JSON.stringify(state))
        } catch {}
        queueRenderAll()
      })
    }
  })()

  const urlParams = new URLSearchParams(window.location.search)
  const backId = urlParams.get('back')
  const backBtn = document.getElementById('btn-back') as HTMLAnchorElement
  if (backId) {
    backBtn.href = `/spools/${backId}`
    ;(document.getElementById('btn-back-label') as HTMLElement).textContent = t('labelPrint.backToSpool')
  }

  const idsParam = urlParams.get('ids') || ''
  const ids = idsParam.split(',').map(Number).filter(n => n > 0)
  const previewContainer = document.getElementById('preview-container')!
  const countEl = document.getElementById('label-count')!

  if (ids.length === 0) {
    countEl.textContent = t('labelPrint.noSpoolsSelected')
  } else {
    countEl.textContent = t('labelPrint.labelsLoading', { count: String(ids.length) })
    ids.forEach(id => previewContainer.insertAdjacentHTML('beforeend', makeLabelHtml(id)))

    const [spoolResults] = await Promise.all([
      Promise.allSettled(ids.map(async id => {
        const r = await fetch(`/api/v1/spools/${id}`, { credentials: 'include' })
        if (!r.ok) throw new Error(`Failed to load spool ${id}: ${r.status}`)
        return await r.json()
      })),
      loadExtraFieldDefs(),
    ])
    spools = spoolResults.filter(r => r.status === 'fulfilled').map(r => (r as PromiseFulfilledResult<ApiSpool>).value)
    designerEditor.refreshExtraFields(getBatchDesignerExtraFields())
    countEl.textContent = spoolResults.length === spools.length
      ? t('labelPrint.labelsReady', { count: String(spools.length) })
      : `${t('labelPrint.labelsReady', { count: String(spools.length) })} (${spools.length}/${ids.length})`

    loadSettings()
    previewZoomControls.sync()
    await prefetchLogos()
    tabControls.activate(activePreviewTab)
  }

  ;[widthInput, heightInput, fontInput, qrSizeInput, zoomInput, checkLogo, checkQR, checkID, checkMfr, checkMat, checkColor, checkColorSwatch, checkColorHex].forEach(el => {
    el.addEventListener('change', () => {
      if (el === zoomInput) previewZoomControls.sync()
      queueRenderAll()
    })
    if (el.type === 'range' || el.type === 'number') {
      el.addEventListener('input', () => {
        if (el === zoomInput) previewZoomControls.sync()
        queueRenderAll()
      })
    }
  })

  document.getElementById('btn-reset')?.addEventListener('click', () => {
    removeStorageValue(SETTINGS_KEY)
    widthInput.value = '60'; heightInput.value = '40'; fontInput.value = '100'; qrSizeInput.value = '18'
    zoomInput.value = '100'
    previewZoomControls.sync()
    checkLogo.checked = checkQR.checked = checkID.checked = checkMfr.checked = checkMat.checked = checkColor.checked = checkColorSwatch.checked = checkColorHex.checked = true
    Object.values(efCheckMap).forEach(cb => { cb.checked = false })
    queueRenderAll()
  })
</script>
