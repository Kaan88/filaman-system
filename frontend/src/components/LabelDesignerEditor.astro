---
const align = [
  { value: 'left', label: 'Left' },
  { value: 'center', label: 'Center' },
  { value: 'right', label: 'Right' },
]

const valign = [
  { value: 'top', id: 'top', label: 'Top' },
  { value: 'center', id: 'mid', label: 'Middle' },
  { value: 'bottom', id: 'bot', label: 'Bottom' },
]

const pill = (items: { value: string; id: string; label: string }[], active: string) => items.map(item => ({
  ...item,
  active: item.value === active,
}))

const verticalAlignButtons = (prefix: string, active = 'bottom') => pill(
  valign.map(item => ({ ...item, id: `${prefix}-${item.id}` })),
  active,
)
---

<div id="tab-panel-designer" class="settings-section" style="display: none;">
  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-presets"><span id="dsh-presets-text">Presets</span></summary>
    <div class="ds-section-body">
      <div>
        <label class="fm-label" id="dsl-preset-saved">Saved presets</label>
        <div class="ds-preset-row">
          <select id="ds-preset-list" class="fm-input fm-select ds-preset-select"></select>
          <button id="ds-preset-load-btn" class="ds-action-btn" type="button">Load</button>
          <button id="ds-preset-delete-btn" class="ds-action-btn ds-action-btn-danger ds-action-btn-icon" type="button" title="Delete selected preset" aria-label="Delete selected preset">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 6h18"/><path d="M8 6V4h8v2"/><path d="M19 6l-1 14H6L5 6"/><path d="M10 11v5"/><path d="M14 11v5"/></svg>
          </button>
        </div>
      </div>
      <div>
        <label class="fm-label" id="dsl-preset-name">Preset name</label>
        <div class="ds-preset-row">
          <input type="text" id="ds-preset-name-input" class="fm-input ds-preset-name-input" placeholder="My label">
          <button id="ds-preset-save-btn" class="ds-action-btn ds-action-btn-primary" type="button">Save as New</button>
        </div>
      </div>
    </div>
  </details>

  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-label">
      <span id="dsl-label-label">Label</span>
      <button class="ds-reset-btn" id="dsr-label" type="button" title="Reset section" aria-label="Reset section">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
    </summary>
    <div class="ds-section-body">
      <div class="ds-dim-grid">
        <div><label class="fm-label" id="dsl-width">W (mm)</label><input type="number" id="ds-width" value="60" min="10" max="300" class="fm-input"></div>
        <div><label class="fm-label" id="dsl-height">H (mm)</label><input type="number" id="ds-height" value="40" min="5" max="200" class="fm-input"></div>
      </div>
      <div class="ds-label-bottom-row">
        <label class="fm-checkbox-group ds-label-border-toggle"><input type="checkbox" id="ds-border"><span id="dsl-border">Print Border</span></label>
        <div class="ds-size-row ds-size-row-compact ds-label-margin-inline">
          <label class="fm-label ds-size-label" id="dsl-margin">Margin (mm)</label>
          <input type="range" id="ds-margin-range" min="0" max="6" step="0.5" value="1" class="ds-slider">
          <input type="number" id="ds-margin" value="1" step="0.5" min="0" max="6" class="fm-input ds-size-num">
        </div>
      </div>
    </div>
  </details>

  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-logo">
      <label class="ds-header-show"><input type="checkbox" id="ds-logo-show" checked><span id="dsl-logo-label">Logo</span></label>
      <button class="ds-reset-btn" id="dsr-logo" type="button" title="Reset section" aria-label="Reset section">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
    </summary>
    <div class="ds-section-body">
      <div class="ds-size-row">
        <label class="fm-label ds-size-label" id="dsl-logo-space">Space (mm)</label>
        <input type="range" id="ds-logo-space-range" min="2" max="20" step="0.5" value="6" class="ds-slider">
        <input type="number" id="ds-logo-space" value="6" step="0.5" min="2" max="20" class="fm-input ds-size-num">
      </div>
      <div class="ds-logo-fit-row">
        <div class="ds-logo-primary-inline">
          <label class="fm-checkbox-group ds-logo-fit-toggle"><input type="checkbox" id="ds-logo-fit" checked><span id="dsl-logo-fit">Scale to fit bounds</span></label>
          <div class="ds-logo-justify-inline">
            <label class="fm-label ds-logo-justify-label" id="dsl-logo-align">Justification</label>
            <div class="ds-align-group" id="ds-logo-align-group" data-value="left">
              {align.map(item => <button class:list={['ds-align-btn', item.value === 'left' && 'active']} data-align={item.value} type="button" title={item.label} aria-label={item.label}>
                {item.value === 'left' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>}
                {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>}
                {item.value === 'right' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>}
              </button>)}
            </div>
          </div>
        </div>
        <div class="ds-logo-manual-inline" id="ds-logo-manual-wrap" hidden>
          <label class="fm-label ds-logo-manual-label" id="dsl-logo-manual">Max logo height (mm)</label>
          <input type="range" id="ds-logo-manual-range" min="2" max="20" step="0.5" value="6" class="ds-slider">
          <input type="number" id="ds-logo-manual" value="6" step="0.5" min="2" max="20" class="fm-input ds-size-num">
        </div>
      </div>
    </div>
  </details>

  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-title">
      <label class="ds-header-show"><input type="checkbox" id="ds-title-show" checked><span id="dsl-title-label">Title</span></label>
      <button class="ds-reset-btn" id="dsr-title" type="button" title="Reset section" aria-label="Reset section">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
    </summary>
    <div class="ds-section-body">
      <div class="ds-size-row">
        <label class="fm-label ds-size-label" id="dsl-title-size">Max size (mm)</label>
        <input type="range" id="ds-title-size-range" min="1" max="20" step="0.5" value="4" class="ds-slider">
        <input type="number" id="ds-title-size" value="4" step="0.5" min="1" max="20" class="fm-input ds-size-num">
      </div>
      <div class="ds-options-row">
        <label class="fm-checkbox-group"><input type="checkbox" id="ds-title-fit" checked><span id="dsl-title-fit">Fit to width</span></label>
        <label class="fm-checkbox-group"><input type="checkbox" id="ds-divider-above"><span id="dsl-divider-above">Line above</span></label>
        <label class="fm-checkbox-group"><input type="checkbox" id="ds-divider-below" checked><span id="dsl-divider-below">Line below</span></label>
      </div>
      <div class="ds-align-combo">
        <div class="ds-align-main-inline">
          <label class="fm-label ds-logo-justify-label" id="dsl-title-align">Justification</label>
          <div class="ds-align-group" id="ds-title-align-group" data-value="left">
            {align.map(item => <button class:list={['ds-align-btn', item.value === 'left' && 'active']} data-align={item.value} type="button" title={item.label} aria-label={item.label}>
              {item.value === 'left' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>}
              {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>}
              {item.value === 'right' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>}
            </button>)}
          </div>
        </div>
        <div class="ds-title-gap-inline">
          <label class="fm-label ds-mini-label" id="dsl-title-gap">Margin (mm)</label>
          <div class="ds-size-row ds-size-row-compact">
            <input type="range" id="ds-title-gap-range" min="-1" max="4" step="0.1" value="0" class="ds-slider">
            <input type="number" id="ds-title-gap" value="0" min="-1" max="4" step="0.1" class="fm-input ds-size-num">
          </div>
        </div>
      </div>
      <div>
        <div class="ds-tpl-label-row"><label class="fm-label" id="dsl-title-tpl">Title Format</label><button class="ds-syntax-btn" id="ds-title-syntax-btn" type="button" title="Template syntax help">?</button></div>
        <textarea id="ds-title-tpl" class="fm-input ds-tpl-input ds-tpl-textarea" rows="1" placeholder="{filament.name}"></textarea>
        <div class="ds-token-area" id="ds-title-token-area"></div>
      </div>

      <div class="ds-secondary-toggle" id="ds-title2-toggle"><label class="fm-checkbox-group ds-secondary-check"><input type="checkbox" id="ds-title2-show"><span id="dsl-title2-show">Subtitle</span></label></div>
      <div id="ds-title2-block" class="ds-secondary-panel" style="display:none">
        <div class="ds-size-row">
          <label class="fm-label ds-size-label" id="dsl-title2-size">Max size (mm)</label>
          <input type="range" id="ds-title2-size-range" min="1" max="20" step="0.5" value="4" class="ds-slider">
          <input type="number" id="ds-title2-size" value="4" step="0.5" min="1" max="20" class="fm-input ds-size-num">
        </div>
        <div class="ds-options-row">
          <label class="fm-checkbox-group"><input type="checkbox" id="ds-title2-fit" checked><span id="dsl-title2-fit">Fit to width</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="ds-title2-divider-above"><span id="dsl-title2-divider-above">Line above</span></label>
          <label class="fm-checkbox-group"><input type="checkbox" id="ds-title2-divider-below"><span id="dsl-title2-divider-below">Line below</span></label>
        </div>
        <div class="ds-align-combo">
          <div class="ds-align-main-inline">
            <label class="fm-label ds-logo-justify-label" id="dsl-title2-align">Justification</label>
            <div class="ds-align-group" id="ds-title2-align-group" data-value="left">
              {align.map(item => <button class:list={['ds-align-btn', item.value === 'left' && 'active']} data-align={item.value} type="button" title={item.label} aria-label={item.label}>
                {item.value === 'left' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>}
                {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>}
                {item.value === 'right' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>}
              </button>)}
            </div>
          </div>
          <div class="ds-title-gap-inline">
            <label class="fm-label ds-mini-label" id="dsl-title2-gap">Margin (mm)</label>
            <div class="ds-size-row ds-size-row-compact">
              <input type="range" id="ds-title2-gap-range" min="-1" max="4" step="0.1" value="0" class="ds-slider">
              <input type="number" id="ds-title2-gap" value="0" min="-1" max="4" step="0.1" class="fm-input ds-size-num">
            </div>
          </div>
        </div>
        <div>
          <div class="ds-tpl-label-row"><label class="fm-label" id="dsl-title2-tpl">Subtitle Format</label><button class="ds-syntax-btn" id="ds-title2-syntax-btn" type="button" title="Template syntax help">?</button></div>
          <textarea id="ds-title2-tpl" class="fm-input ds-tpl-input ds-tpl-textarea" rows="1" placeholder="{filament.type}"></textarea>
          <div class="ds-token-area" id="ds-title2-token-area"></div>
        </div>
      </div>
    </div>
  </details>

  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-qr">
      <label class="ds-header-show"><input type="checkbox" id="ds-qr-show" checked><span id="dsl-qr-label">QR Code</span></label>
      <button class="ds-reset-btn" id="dsr-qr" type="button" title="Reset section" aria-label="Reset section">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
    </summary>
    <div class="ds-section-body">
      <div class="ds-qr-top-row">
        <div class="ds-qr-mode-inline">
          <label class="fm-label" id="dsl-qr-mode">Mode</label>
          <div class="ds-qr-mode-select" id="ds-qr-mode-select">
            <select id="ds-qr-mode" class="ds-native-select" tabindex="-1" aria-hidden="true">
              <option value="simple" selected id="dso-qr-simple">Simple</option>
              <option value="logo" id="dso-qr-logo">Logo</option>
              <option value="colorLogo" id="dso-qr-color-logo">Color Logo</option>
            </select>
            <button id="ds-qr-mode-button" class="fm-input ds-mode-button" type="button" aria-haspopup="listbox" aria-expanded="false">
              <span class="ds-mode-current-icon" id="ds-qr-mode-current-icon" aria-hidden="true"></span>
              <span class="ds-mode-current-label" id="ds-qr-mode-current-label">Simple</span>
            </button>
            <div class="ds-mode-menu" id="ds-qr-mode-menu" role="listbox" hidden>
              <button type="button" class="ds-mode-option" data-mode="simple" role="option" aria-selected="true"><span id="dsm-qr-simple-label">Simple</span></button>
              <button type="button" class="ds-mode-option" data-mode="logo" role="option" aria-selected="false"><span class="ds-mode-wordmark" aria-hidden="true">FilaMan</span><span id="dsm-qr-logo-label">Logo</span></button>
              <button type="button" class="ds-mode-option" data-mode="colorLogo" role="option" aria-selected="false"><img src="/logo.png" class="ds-mode-logo" alt="" aria-hidden="true"><span id="dsm-qr-color-logo-label">Color Logo</span></button>
            </div>
          </div>
        </div>
        <div class="ds-qr-size-inline">
          <label class="fm-label ds-size-label" id="dsl-qr-size">Size (mm)</label>
          <div class="ds-size-row ds-size-row-compact">
            <input type="range" id="ds-qr-size-range" min="5" max="60" step="1" value="18" class="ds-slider">
            <input type="number" id="ds-qr-size" value="18" step="1" min="5" max="60" class="fm-input ds-size-num">
          </div>
        </div>
      </div>
      <div><label class="fm-label" id="dsl-qr-link">Link mode</label><div class="ds-pill-group" id="ds-qr-link-group" data-value="spool">
        {pill([{ value: 'url', id: 'dsp-qr-url', label: 'Custom URL' }, { value: 'spool', id: 'dsp-qr-spool', label: 'Spool URL' }], 'spool').map(item => <button class:list={['ds-pill-btn', item.active && 'active']} data-val={item.value} id={item.id} type="button">{item.label}</button>)}
      </div></div>
      <div id="ds-qr-url-wrap" style="display:none;"><label class="fm-label" id="dsl-qr-url-tpl">Custom URL base</label><input type="text" id="ds-qr-url-tpl" class="fm-input ds-tpl-input" placeholder="https://example.com"></div>
      <div class="ds-two-col-row">
        <div class="ds-field-col"><label class="fm-label" id="dsl-qr-pos">Position</label><div class="ds-pill-group" id="ds-qr-pos-group" data-value="right">
          {pill([{ value: 'left', id: 'dsp-qr-left', label: 'Left' }, { value: 'right', id: 'dsp-qr-right', label: 'Right' }], 'right').map(item => <button class:list={['ds-pill-btn', 'ds-icon-pill-btn', item.active && 'active']} data-val={item.value} id={item.id} type="button" title={item.label} aria-label={item.label}>
            {item.value === 'left' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>}
            {item.value === 'right' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>}
          </button>)}
        </div></div>
        <div class="ds-field-col"><label class="fm-label" id="dsl-qr-valign">Vertical align</label><div class="ds-pill-group ds-valign-group" id="ds-qr-valign-group" data-value="bottom">
          {verticalAlignButtons('dsp-qr').map(item => <button class:list={['ds-pill-btn', 'ds-valign-btn', item.active && 'active']} data-val={item.value} id={item.id} type="button" title={item.label} aria-label={item.label}>
            {item.value === 'top' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="5" x2="19" y2="5"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>}
            {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="8" y1="8" x2="16" y2="8"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="8" y1="16" x2="16" y2="16"/></svg>}
            {item.value === 'bottom' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="5" y1="19" x2="19" y2="19"/></svg>}
          </button>)}
        </div></div>
      </div>
    </div>
  </details>

  <details class="ds-section" open>
    <summary class="ds-section-header" id="dsh-info">
      <label class="ds-header-show"><input type="checkbox" id="ds-info-show" checked><span id="dsl-info-label">Information</span></label>
      <button class="ds-reset-btn" id="dsr-info" type="button" title="Reset section" aria-label="Reset section">
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 12a9 9 0 1 0 3-6.7"/><path d="M3 4v5h5"/></svg>
      </button>
    </summary>
    <div class="ds-section-body">
      <div class="ds-size-row">
        <label class="fm-label ds-size-label" id="dsl-info-size">Text size (mm)</label>
        <input type="range" id="ds-info-size-range" min="1" max="10" step="0.5" value="2.5" class="ds-slider">
        <input type="number" id="ds-info-size" value="2.5" step="0.5" min="1" max="10" class="fm-input ds-size-num">
      </div>
      <div class="ds-title-gap-inline">
        <label class="fm-label ds-mini-label" id="dsl-info-gap">Margin (mm)</label>
        <div class="ds-size-row ds-size-row-compact">
          <input type="range" id="ds-info-gap-range" min="-1" max="4" step="0.1" value="0" class="ds-slider">
          <input type="number" id="ds-info-gap" value="0" min="-1" max="4" step="0.1" class="fm-input ds-size-num">
        </div>
      </div>
      <div class="ds-two-col-row">
        <div class="ds-field-col"><label class="fm-label" id="dsl-info-halign">Justification</label><div class="ds-align-group" id="ds-info-align-group" data-value="left">
          {align.map(item => <button class:list={['ds-align-btn', item.value === 'left' && 'active']} data-align={item.value} type="button" title={item.label} aria-label={item.label}>
            {item.value === 'left' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="15" y2="12"/><line x1="3" y1="18" x2="18" y2="18"/></svg>}
            {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="6" y1="12" x2="18" y2="12"/><line x1="4" y1="18" x2="20" y2="18"/></svg>}
            {item.value === 'right' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="3" y1="6" x2="21" y2="6"/><line x1="9" y1="12" x2="21" y2="12"/><line x1="6" y1="18" x2="21" y2="18"/></svg>}
          </button>)}
        </div></div>
        <div class="ds-field-col"><label class="fm-label" id="dsl-info-valign">Vertical align</label><div class="ds-pill-group ds-valign-group" id="ds-info-valign-group" data-value="bottom">
          {verticalAlignButtons('dsip').map(item => <button class:list={['ds-pill-btn', 'ds-valign-btn', item.active && 'active']} data-val={item.value} id={item.id} type="button" title={item.label} aria-label={item.label}>
            {item.value === 'top' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="5" y1="5" x2="19" y2="5"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/></svg>}
            {item.value === 'center' && <svg viewBox="0 0 24 24" aria-hidden="true"><line x1="8" y1="8" x2="16" y2="8"/><line x1="5" y1="12" x2="19" y2="12"/><line x1="8" y1="16" x2="16" y2="16"/></svg>}
