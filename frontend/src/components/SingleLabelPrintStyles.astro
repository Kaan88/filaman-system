    display: flex;
    align-items: safe center;
    justify-content: safe center;
    padding: 40px;
    overflow: auto;
  }

  .label-preview {
    background: white;
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    padding: 2mm;
